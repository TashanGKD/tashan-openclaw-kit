# -----------------------------------------------------------------------------
# OpenClaw runtime
# -----------------------------------------------------------------------------
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# Model providers: fill at least one
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Optional web providers
# -----------------------------------------------------------------------------
BRAVE_API_KEY=
PERPLEXITY_API_KEY=
FIRECRAWL_API_KEY=

# -----------------------------------------------------------------------------
# Optional remote browser provider
# -----------------------------------------------------------------------------
BROWSERBASE_API_KEY=
