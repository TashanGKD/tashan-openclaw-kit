{
  gateway: {
    mode: "local",
    port: 18789,
    bind: "loopback",
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      bootstrapMaxChars: 12000,
      bootstrapTotalMaxChars: 60000,
      bootstrapPromptTruncationWarning: "once",
      model: {
        primary: "openai/gpt-5.2",
        fallbacks: ["anthropic/claude-sonnet-4-5", "google/gemini-3-flash-preview"],
      },
      models: {
        "openai/gpt-5.2": { alias: "gpt" },
        "anthropic/claude-sonnet-4-5": { alias: "sonnet" },
        "google/gemini-3-flash-preview": { alias: "gemini" },
      },
      thinkingDefault: "low",
      verboseDefault: "off",
      timeoutSeconds: 600,
      maxConcurrent: 3,
      memorySearch: {
        enabled: true,
        query: {
          maxResults: 8,
          minScore: 0.2,
        },
        sync: {
          onSessionStart: true,
          watch: true,
          watchDebounceMs: 800,
        },
      },
      compaction: {
        reserveTokensFloor: 20000,
        memoryFlush: {
          enabled: true,
          softThresholdTokens: 4000,
          systemPrompt: "Session nearing compaction. Store durable memory before context is compacted.",
          prompt:
            "Write durable facts to MEMORY.md and dated notes to memory/YYYY-MM-DD.md. Reply with NO_REPLY if nothing should be stored.",
        },
      },
      sandbox: {
        mode: "off",
      },
    },
  },

  plugins: {
    slots: {
      memory: "memory-core",
    },
    entries: {
      firecrawl: {
        enabled: true,
      },
    },
  },

  browser: {
    enabled: true,
    defaultProfile: "openclaw",
  },

  skills: {
    load: {
      extraDirs: [],
    },
  },

  tools: {
    exec: {
      backgroundMs: 10000,
      timeoutSec: 1800,
      cleanupMs: 1800000,
    },
    fs: {
      workspaceOnly: true,
    },
    web: {
      search: {
        enabled: true,
      },
      fetch: {
        firecrawl: {
          baseUrl: "https://api.firecrawl.dev",
          onlyMainContent: true,
          maxAgeMs: 172800000,
          timeoutSeconds: 60,
        },
      },
    },
  },
}
